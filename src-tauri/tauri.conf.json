{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fika",
  "version": "0.1.0",
  "identifier": "com.mac.fika",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "fika",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "name": "Code and Text Files",
        "description": "Open code and text files in fika",
        "role": "Editor",
        "contentTypes": [
          "public.text",
          "public.plain-text",
          "public.source-code",
          "public.json"
        ],
        "ext": [
          "txt",
          "md",
          "json",
          "js",
          "jsx",
          "ts",
          "tsx",
          "mjs",
          "cjs",
          "html",
          "css",
          "scss",
          "less",
          "py",
          "rs",
          "go",
          "java",
          "kt",
          "swift",
          "rb",
          "php",
          "sh",
          "bash",
          "zsh",
          "toml",
          "yaml",
          "yml",
          "xml",
          "sql",
          "env",
          "gitignore",
          "lock",
          "csv",
          "log"
        ]
      },
      {
        "name": "Folders",
        "description": "Open folders in fika",
        "role": "Editor",
        "contentTypes": [
          "public.folder",
          "public.directory"
        ],
        "ext": [
          "folder"
        ]
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
